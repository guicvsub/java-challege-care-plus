			"item": [
				{
					"name": "POST /login - Login Válido",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Testar se o login foi bem-sucedido",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has tokenJWT\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('tokenJWT');",
									"    pm.expect(jsonData.tokenJWT).to.be.a('string');",
									"    pm.expect(jsonData.tokenJWT).to.not.be.empty;",
									"});",
									"",
									"// Salvar o token para uso em outras requisições",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.collectionVariables.set('jwt_token', jsonData.tokenJWT);",
									"    console.log('Token JWT salvo com sucesso!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"usuario1@careplus.com\",\n  \"senha\": \"minha_senha_secreta\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Login com credenciais válidas para obter token JWT\n\n**Credenciais Testadas:**\n- Email: usuario1@careplus.com\n- Senha: minha_senha_secreta\n\n**Resposta Esperada:**\n```json\n{\n  \"tokenJWT\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}\n```"
					},
					"response": []
				},
