		{
			"name": "4. Validação de Token",
			"item": [
				{
					"name": "Validar Estrutura do Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Primeiro fazer login para obter token",
									"pm.sendRequest({",
									"    url: pm.collectionVariables.get('baseUrl') + '/login',",
									"    method: 'POST',",
									"    header: {",
									"        'Content-Type': 'application/json'",
									"    },",
									"    body: {",
									"        mode: 'raw',",
									"        raw: JSON.stringify({",
									"            login: 'usuario1@careplus.com',",
									"            senha: 'minha_senha_secreta'",
									"        })",
									"    }",
									"}, function (err, res) {",
									"    if (err) {",
									"        console.log('Erro no login:', err);",
									"        return;",
									"    }",
									"    ",
									"    if (res.code === 200) {",
									"        const token = res.json().tokenJWT;",
									"        const parts = token.split('.');",
									"        const payload = JSON.parse(atob(parts[1]));",
									"        ",
									"        pm.test(\"Token has required claims\", function () {",
									"            pm.expect(payload).to.have.property('iss');",
									"            pm.expect(payload).to.have.property('sub');",
									"            pm.expect(payload).to.have.property('exp');",
									"        });",
									"        ",
									"        pm.test(\"Token issuer is 'Care Plus API'\", function () {",
									"            pm.expect(payload.iss).to.eql('Care Plus API');",
									"        });",
									"        ",
									"        pm.test(\"Token subject is email\", function () {",
									"            pm.expect(payload.sub).to.eql('usuario1@careplus.com');",
									"        });",
									"        ",
									"        pm.test(\"Token is not expired\", function () {",
									"            const expTime = payload.exp * 1000;",
									"            const currentTime = Date.now();",
									"            pm.expect(expTime).to.be.greaterThan(currentTime);",
									"        });",
									"        ",
									"        console.log('Token validado com sucesso!');",
									"        console.log('Payload:', payload);",
									"    } else {",
									"        pm.test(\"Login successful for token validation\", function () {",
									"            pm.expect.fail('Login falhou na validação do token');",
									"        });",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"login\": \"usuario1@careplus.com\",\n  \"senha\": \"minha_senha_secreta\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Valida a estrutura e conteúdo do token JWT gerado"
					},
					"response": []
				}
			],
			"description": "Testes específicos para validação de tokens JWT"
