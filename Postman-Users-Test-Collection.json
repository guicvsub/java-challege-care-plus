							"listen": "test",
							"script": {
								"exec": [
									"// Reference information about test users",
									"pm.test(\"Users Reference\", function () {",
									"    console.log('=== CARE PLUS TEST USERS ===');",
									"    console.log('1. admin@careplus.com / Admin@123 (Administrator)');",
									"    console.log('2. usuario@careplus.com / password (Regular User)');",
									"    console.log('3. testsenha@careplus.com / Test@1234 (Password Validation)');",
									"    console.log('4. sessao@careplus.com / Admin@123 (Session Active - 2min)');",
									"    console.log('5. expirado@careplus.com / Admin@123 (Session Expired - 6min)');",
									"    console.log('6. sqltest@careplus.com / Sql@1234 (SQL Injection Test)');",
									"    console.log('7. token@careplus.com / Token@1234 (Token Tampering Test)');",
									"    console.log('=============================');",
									"    pm.expect(true).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/auth/validate",
