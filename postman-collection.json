	"item": [
		{
			"name": "Patient Operations",
			"item": [
				{
					"name": "Create Patient",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201 Created\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has patient data\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('nome');",
									"    pm.expect(jsonData).to.have.property('cpf');",
									"    pm.expect(jsonData).to.have.property('email');",
									"    pm.expect(jsonData).to.have.property('telefone');",
									"});",
									"",
									"pm.test(\"Patient data is valid\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.nome).to.be.a('string');",
									"    pm.expect(jsonData.cpf).to.be.a('string');",
									"    pm.expect(jsonData.email).to.include('@');",
									"});",
									"",
									"// Store created patient ID for later tests",
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set(\"createdPatientId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"João Silva\",\n  \"cpf\": \"123.456.789-00\",\n  \"email\": \"joao.silva@email.com\",\n  \"telefone\": \"(11) 98765-4321\",\n  \"dataNascimento\": \"1990-05-15\",\n  \"convenio\": \"Unimed\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/pacientes",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"pacientes"
							]
						}
					},
					"response": []
				},
				{
					"name": "List All Patients",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Each patient has required fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        jsonData.forEach(patient => {",
									"            pm.expect(patient).to.have.property('id');",
									"            pm.expect(patient).to.have.property('nome');",
									"            pm.expect(patient).to.have.property('cpf');",
									"            pm.expect(patient).to.have.property('email');",
									"        });",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/pacientes",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"pacientes"
							]
						}
					},
					"response": []
				},
